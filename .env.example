# =============================================================================
# Quran Halaqat & Camp Management System — Environment Variables (template)
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in real values. NEVER commit .env itself - only .env.example
# belongs in git (already enforced in .gitignore).
#
# In production, set these as real environment variables on your host
# (Vercel Project Settings -> Environment Variables, a Docker --env-file,
# systemd EnvironmentFile=, etc.) rather than shipping a .env file at all.
# =============================================================================


# -----------------------------------------------------------------------
# Database (PostgreSQL via Prisma v7)
# -----------------------------------------------------------------------
# Prisma v7 wants a connection string in TWO roles, not one - this is new
# as of v7 and easy to get backwards:
#
#   DATABASE_URL - used by the running app (src/lib/prisma.ts) on every
#     request. Point this at a POOLED connection if your host offers one
#     (PgBouncer, Neon's "-pooler" hostname, Supabase's port 6543, etc.).
#     This matters most on serverless platforms like Vercel, where each
#     request can spin up a fresh function instance and therefore a
#     fresh DB connection - without pooling you exhaust Postgres's
#     connection limit fast.
#
#   DIRECT_URL - used ONLY by the Prisma CLI (generate / migrate / db
#     push / studio - see prisma.config.ts at the project root), which
#     falls back to DATABASE_URL if this isn't set. Optional, but should
#     be a DIRECT, unpooled connection when you do set it: pooled
#     "transaction mode" connections don't preserve the session state
#     migrations need, and using one here can fail with "prepared
#     statement already exists".
#
# No separate pooler in your setup (plain self-hosted Postgres, a small
# non-serverless deployment)? Skip DIRECT_URL entirely - the fallback
# means DATABASE_URL alone is enough.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Neon specifically: the pooled/direct distinction is the hostname, not
# the port - "-pooler" is inserted into the same hostname, same port
# 5432, and channel_binding=require is Neon's own MITM-resistant auth
# extra (harmless to include, safe to omit if a driver doesn't recognize
# it):
#
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
#
# Generic PgBouncer / Supabase instead look more like a different PORT on
# the same host, plus an explicit pgbouncer flag:
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler:6543/DBNAME?pgbouncer=true&connection_limit=5&pool_timeout=30"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"


# -----------------------------------------------------------------------
# Auth.js (next-auth@beta / v5)
# -----------------------------------------------------------------------
# AUTH_SECRET - encrypts session JWTs and CSRF tokens. Required in every
# environment, and should be a DIFFERENT value per environment (dev,
# staging, prod each get their own - never reuse one across them, and
# never reuse the example value from this repo's README anywhere real).
# Generate one with:
#   openssl rand -base64 32
# or let Auth.js generate and write it for you:
#   npx auth secret

AUTH_SECRET=""

# AUTH_URL - the canonical URL of THIS deployment. (The older name
# NEXTAUTH_URL is still recognized for compatibility - set one or the
# other, not both, to avoid confusing yourself later.)
#   Local dev:          http://localhost:3000
#   Vercel PRODUCTION:  usually not needed - Vercel sets this
#                        automatically from its own system env vars.
#   Vercel PREVIEW, or any self-hosted deploy (Docker, a VPS, Railway,
#   Render, etc.): set this explicitly. Without it, session cookies and
#   internal redirects (proxy.ts sending an unauthenticated visitor to
#   /login, for example) can resolve against the wrong host.

AUTH_URL="http://localhost:3000"

# AUTH_TRUST_HOST - tells Auth.js to trust the X-Forwarded-Host header
# from a reverse proxy in front of the app. Required (set to "true") on
# any self-hosted deployment behind nginx/Caddy/a load balancer, inside
# Docker, or on most non-Vercel platforms - omit it there and you'll hit
# an UntrustedHost error on first sign-in. Vercel sets this
# automatically for you, but leaving it set to true is harmless there
# too, so the same .env works unmodified across hosts.

AUTH_TRUST_HOST="true"


# -----------------------------------------------------------------------
# App URL (public)
# -----------------------------------------------------------------------
# Distinct from AUTH_URL above, which Auth.js uses internally for its
# own cookie/redirect handling. This one is for anything else - Server
# Actions or client code - that needs to build an absolute URL (a
# shareable link, a QR code, a print header). Must be prefixed
# NEXT_PUBLIC_ to be readable from browser code, per Next.js convention;
# anything without that prefix stays server-only and is invisible to the
# client bundle. Nothing shipped so far reads this yet, but the Phase 1
# "Dynamic Settings" and Phase 4 "Reports" features are exactly the kind
# of place a future absolute link would need it, so it's here in advance.

NEXT_PUBLIC_APP_URL="http://localhost:3000"
